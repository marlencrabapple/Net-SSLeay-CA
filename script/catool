    exec(
        [
            @$openssl,            qw(x509 -req -in),
            "$CAtop/$newCAcsr",   qw(copy_extensions copyall -out),
            $newCAcert,           '-set_subject',
            $subj->mutlivalue_SH, '-key',
            "$newCAkey",          @days
        ]
    );
}

