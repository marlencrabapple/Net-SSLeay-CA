#const our @CA_HEIRARCHY_RANK = qw(q);
field $openssl;
field $isroot = 1;
field $issub;

#field $CAkey;
field $newCAkey;

#field $CAcert;
field $newCAcert;    #//=$CAkey;
field $newCAcsr;

field $signingCA;
field $signingCAkey;
field $keyalgo = 'RSA';
field $keybits = 4096;
field $CAtop   = "ENV{HOME}/.local/ca";
field @days    = ();                      #$days;
                                          #$CA_HEIRARCHY_RANK[0];
field $CApathlen =
  $issub && !$isroot ? 0 : 1;             #$CArank ne $CA_HEIRARCHY_RANK[0];

field $CArank = 'Local';
field $CArev;

field $hostfqdn  = Net::Domain::hostfqdn;
field $localuser = `whoami`;

field $subj = (
    class {
        field $cn : param;
        field $o  : param;
        field $ou : param;
    }
)->new(
    cn => "$localuser@$hostfqdn $CArank CA 《$keyalgo$keybits✖$CArev》",
    o  => "$hostfqdn",
    ou => "Local User"
);

method run : common ($argv = \@ARGV) {
    my ( $self, $cliopts ) = $class->new->cliopts(
        argv    => $argv,
        optspec => {
            'CAcert=s',
            'CAkey=s',
            'signingCAcert=s',
            'signingCAkey=s',
            'CAcsr', 'days',
            'keyalgo',
            'keybits',
            'san|subject-alternative-name|',
            '<>' => sub ( $self, $barearg ) {
                if ( my $field = $class->isvalid($barearg) ) {
                    $self->addfield($field)
                      // fatal(
                        "Error processing '$field' as a valid SAN value");
                }
            }
        }
    );
}

