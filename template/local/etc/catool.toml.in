#
# Default user configuration file for catool [% version() %]
#
# Run `catool newca --from-config` to generate a working subordinate CA for the
# local user suitable for most uses (provided the file is unmodified). Values
# can contain special variables and functions that will be replaced when the
# configuration file is validated. See `man(1) catool` or `catool help config`
# for further information.
#

[default_ca]
parent_ca = "root_ca" # a key from this or another file with the issuing CA
                      # configuration

#parent_certfile="" # for signing this CA and generating fullchain.pem bundle
#parent_keyfile="" # for signing this CA if not already created
#csr="" # path to a user provided CSR

catop = "<: $data_home :>" # all files are relative to this
                           # path unless absolute paths
                           # themselves

certfile = "<: $subj_cn.slug() :>.pem"
keyfile = "private/<: $subj_cn.slug() :>-key.pem"
subj_cn = "<: whoami() :>@<: hostfqdn() :> Intermediate CA"

config = "/etc/catool/cnf/sub_ca.cnf"
req_config = "/etc/catool/cnf/leaf_server.cnf"
